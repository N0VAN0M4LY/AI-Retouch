<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow Electron's V8 JIT -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Allow loading unsigned dynamic libraries (native modules like sharp) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Allow dyld env variables (needed for some native modules) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Network access (API calls to AI providers, license verification) -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- File access (reading/writing images for retouching) -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
