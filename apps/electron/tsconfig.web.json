{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "outDir": "out",
    "typeRoots": ["./node_modules/@types", "../../packages/shared/node_modules/@types"],
    "paths": {
      "@ai-retouch/shared": ["../../packages/shared/src/index.ts"],
      "@ai-retouch/ui-core": ["../../packages/ui-core/src/index.ts"],
      "@ai-retouch/ui-core/*": ["../../packages/ui-core/src/*"]
    }
  },
  "include": ["src/renderer/**/*"]
}
