{
  "manifestVersion": 5,
  "id": "com.airetouch.plugin",
  "name": "AI Retouch",
  "version": "0.0.1",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "24.0.0"
  },
  "icons": [
    { "width": 48, "height": 48, "path": "icons/plugin-icon.png", "scale": [1, 2] }
  ],
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "fullAccess",
    "launchProcess": {
      "schemes": ["https"],
      "extensions": [".exe"]
    }
  },
  "featureFlags": {
    "enableFill": true,
    "CSSNextSupport": true
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "ai-retouch-panel",
      "label": {
        "default": "AI Retouch"
      },
      "icons": [
        { "width": 23, "height": 23, "path": "icons/icon_D.png", "scale": [1, 2], "theme": ["darkest", "dark", "medium"] },
        { "width": 23, "height": 23, "path": "icons/icon_N.png", "scale": [1, 2], "theme": ["lightest", "light"] }
      ],
      "minimumSize": {
        "width": 200,
        "height": 200
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 520
      },
      "preferredFloatingSize": {
        "width": 450,
        "height": 560
      }
    }
  ]
}

