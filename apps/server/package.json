{
  "name": "@ai-retouch/server",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsup src/index.ts --format esm --target node18 --platform node --out-dir dist --clean",
    "build:pack": "tsup --config tsup.pack.ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ai-retouch/shared": "workspace:*",
    "@google/genai": "^1.45.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "openai": "^6.29.0",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "@types/sharp": "^0.32.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@types/yauzl": "^2.10.3",
    "bytenode": "^1.5.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
