{
  "name": "@ai-retouch/ui-core",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api/index.ts",
    "./api/*": "./src/api/*.ts",
    "./hooks": "./src/hooks/index.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./pages": "./src/pages/index.ts",
    "./pages/*": "./src/pages/*.tsx",
    "./pages/settings/*": "./src/pages/settings/*.tsx",
    "./platform": "./src/platform/index.ts",
    "./platform/*": "./src/platform/*.ts",
    "./i18n": "./src/i18n/index.ts",
    "./i18n/*": "./src/i18n/*.ts",
    "./theme": "./src/theme/index.ts",
    "./theme/*": "./src/theme/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-retouch/shared": "workspace:*"
  },
  "peerDependencies": {
    "i18next": ">=24.0.0",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0",
    "react-i18next": ">=15.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.3"
  }
}
